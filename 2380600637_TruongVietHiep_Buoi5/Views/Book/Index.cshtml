@model IEnumerable<_2380600637_TruongVietHiep_Buoi5.Models.Book>

@{
    ViewData["Title"] = "Thêm mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary m-0">
        <a asp-action="Create" class="text-decoration-none">Thêm mới</a>
    </h3>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-light">
                <div class="card-header bg-white border-bottom-0 pb-0 text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-primary text-decoration-none">Edit</a>
                </div>
                <div class="card-body">
                    <p class="card-text mb-1"><strong>Tác giả:</strong> @item.Author</p>
                    <p class="card-text mb-3"><strong>Thể loại:</strong> @(_2380600637_TruongVietHiep_Buoi5.Models.MockData.Categories.FirstOrDefault(c => c.Id == item.CategoryId)?.Name)</p>
                    <div class="text-center mb-3">
                        <img src="@item.ImageUrl" class="img-fluid rounded" alt="@item.Title" style="max-height: 200px; object-fit: cover;">
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 d-flex justify-content-end gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-success btn-sm text-white">Xóa</a>
                </div>
            </div>
        </div>
    }
</div>
