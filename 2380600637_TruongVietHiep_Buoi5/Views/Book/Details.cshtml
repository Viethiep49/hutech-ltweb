@model _2380600637_TruongVietHiep_Buoi5.Models.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";
}

<h3 class="text-uppercase mb-4 text-secondary">THÔNG TIN CHI TIẾT SÁCH</h3>

<div class="row mt-4 p-4 border rounded bg-white shadow-sm">
    <div class="col-md-4 text-center">
        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded" style="max-height: 400px; object-fit:contain;" />
    </div>
    <div class="col-md-8">
        <h4 class="text-danger fw-bold">Tên sách: @Model.Title</h4>
        <p class="fs-5"><strong>Tác giả:</strong> @Model.Author</p>
        <p><strong>Nhà cung cấp:</strong> NXB Trẻ</p>
        <p><strong>Nhà xuất bản:</strong> NXB Trẻ</p>
        <p class="text-warning">★★★★★ <span class="text-muted">(79 đánh giá)</span></p>

        <p class="mt-3">
            <strong>Mô tả:</strong> <br />
            @Model.Description
        </p>

        <h4 class="text-danger fw-bold mt-4">@string.Format("{0:N0}", Model.Price) đ <span class="text-muted text-decoration-line-through fs-6 ms-2">80.000 đ</span> <span class="badge bg-danger ms-2">-23%</span></h4>

        <div class="d-flex align-items-center mt-4">
            <span class="me-3">Số lượng:</span>
            <div class="input-group" style="width: 120px;">
                <button class="btn btn-outline-secondary" type="button">-</button>
                <input type="text" class="form-control text-center" value="1">
                <button class="btn btn-outline-secondary" type="button">+</button>
            </div>
        </div>

        <div class="mt-4 gap-3 d-flex">
            <button class="btn btn-outline-danger px-4 py-2"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</button>
            <button class="btn btn-danger px-5 py-2">Mua ngay</button>
        </div>
        
        <div class="mt-3">
            <a asp-action="Index" class="text-decoration-none">&larr; Quay lại danh sách</a>
        </div>
    </div>
</div>
