@model _2380600637_TruongVietHiep_Buoi5.Models.Book

@{
    ViewData["Title"] = "Xóa Sách";
}

<h3 class="text-danger mb-4">Bạn có chắc chắn muốn xóa cuốn sách này?</h3>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded" style="max-height: 250px;" />
                    </div>
                    <div class="col-md-8">
                        <h4 class="card-title fw-bold">@Model.Title</h4>
                        <p class="card-text mb-1"><strong>Tác giả:</strong> @Model.Author</p>
                        <p class="card-text mb-1"><strong>Chủ đề:</strong> @(_2380600637_TruongVietHiep_Buoi5.Models.MockData.Categories.FirstOrDefault(c => c.Id == Model.CategoryId)?.Name)</p>
                        <h4 class="text-danger mt-3">@string.Format("{0:N0}", Model.Price) đ</h4>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white text-end">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <input type="submit" value="Xác nhận Xóa" class="btn btn-danger px-4" />
                </form>
            </div>
        </div>
    </div>
</div>
