@model IEnumerable<thuongmaidientu.Models.Product>

@{
    ViewData["Title"] = "Admin: Quản lý sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 text-danger">@ViewData["Title"]</h1>
        <a asp-area="Admin" asp-action="Create" class="btn btn-danger">
            <i class="bi bi-plus-circle"></i> Thêm mới sản phẩm
        </a>
    </div>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Danh mục</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td class="align-middle fw-bold">@item.Name</td>
                <td class="align-middle">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                <td class="align-middle">
                    <span class="badge bg-info text-dark">@item.Category?.Name</span>
                </td>
                <td class="text-center align-middle">
                    <div class="btn-group">
                        <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-area="Admin" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </div>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
