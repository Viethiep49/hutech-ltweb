@model IEnumerable<thuongmaidientu.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng sản phẩm";
    var categories = ViewBag.Categories as IEnumerable<thuongmaidientu.Models.Category>;
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar: Categories -->
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-list-ul"></i> Danh mục</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" asp-route-categoryId="" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["categoryId"] == null ? "active" : "")">
                        Tất cả sản phẩm
                    </a>
                    @if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            <a asp-action="Index" asp-route-categoryId="@cat.Id" 
                               class="list-group-item list-group-item-action @(Context.Request.Query["categoryId"] == cat.Id.ToString() ? "active" : "")">
                                @cat.Name
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Main: Product List -->
        <div class="col-md-9">
            <h2 class="mb-4">@ViewData["Title"]</h2>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card">
                            <div class="bg-light text-center py-5">
                                <i class="bi bi-laptop display-1 text-muted"></i>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@item.Name</h5>
                                <p class="card-text text-danger fs-5 fw-bold">
                                    @item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                                </p>
                                <span class="badge bg-secondary mb-3">@item.Category?.Name</span>
                            </div>
                            <div class="card-footer bg-white border-0 pb-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary w-100">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            @if (!Model.Any())
            {
                <div class="alert alert-info mt-4 text-center">
                    Không tìm thấy sản phẩm nào trong danh mục này.
                </div>
            }
        </div>
    </div>
</div>

<style>
    .product-card { transition: transform 0.2s; }
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>
