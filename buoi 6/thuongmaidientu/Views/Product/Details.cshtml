@model thuongmaidientu.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">@ViewData["Title"]: @Model.Name</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <!-- Placeholder for product image -->
                            <div class="bg-light border rounded d-flex align-items-center justify-content-center mb-3" style="height: 250px;">
                                <i class="bi bi-image text-muted display-1"></i>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <h2 class="text-primary">@Html.DisplayFor(model => model.Name)</h2>
                            <h3 class="text-success mb-4">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h3>
                            
                            <div class="mb-4">
                                <h5 class="fw-bold border-bottom pb-2">Thông tin chi tiết</h5>
                                <dl class="row">
                                    <dt class="col-sm-4 text-muted">Danh mục</dt>
                                    <dd class="col-sm-8"><span class="badge bg-secondary">@Html.DisplayFor(model => model.Category.Name)</span></dd>
                                    
                                    <dt class="col-sm-4 text-muted mt-2">Mô tả</dt>
                                    <dd class="col-sm-8">
                                        <p class="text-justify">@(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả cho sản phẩm này." : Model.Description)</p>
                                    </dd>
                                </dl>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
                                    <i class="bi bi-pencil"></i> Chỉnh sửa
                                </a>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
