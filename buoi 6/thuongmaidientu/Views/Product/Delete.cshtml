@model thuongmaidientu.Models.Product

@{
    ViewData["Title"] = "Xác nhận xóa sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> @ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <p class="lead">Bạn có chắc chắn muốn xóa sản phẩm này không?</p>
                    <hr />
                    <dl class="row">
                        <dt class = "col-sm-4 fw-bold">Tên sản phẩm</dt>
                        <dd class = "col-sm-8">@Html.DisplayFor(model => model.Name)</dd>
                        <dt class = "col-sm-4 fw-bold">Giá bán</dt>
                        <dd class = "col-sm-8 text-danger fw-bold">
                            @Model.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                        </dd>
                        <dt class = "col-sm-4 fw-bold">Danh mục</dt>
                        <dd class = "col-sm-8">@Html.DisplayFor(model => model.Category.Name)</dd>
                    </dl>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Quay lại</a>
                            <button type="submit" class="btn btn-danger px-5">Xác nhận xóa</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
